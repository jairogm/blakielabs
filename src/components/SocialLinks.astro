---
import { getLang, socialLinks, useTranslations } from "../i18n/ui.js";

const { className = "" } = Astro.props;
const lang = getLang(Astro);
const t = useTranslations(lang);
---

<div class={`social-links ${className}`} aria-label={t.socials.aria}>
  {socialLinks.map((link) => (
    <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} title={link.label}>
      {link.id === "instagram" ? (
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <rect x="3.5" y="3.5" width="17" height="17" rx="5" />
          <circle cx="12" cy="12" r="3.8" />
          <circle cx="16.8" cy="7.2" r="0.8" fill="currentColor" stroke="none" />
        </svg>
      ) : (
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="6.8" cy="7" r="1.45" fill="currentColor" stroke="none" />
          <path d="M5.45 10.15 H8.15 V18.6 H5.45 Z" fill="currentColor" stroke="none" />
          <path d="M10.35 10.15 H12.95 V11.35 C13.45 10.6 14.35 9.9 15.8 9.9 C18.15 9.9 19.3 11.45 19.3 14.25 V18.6 H16.6 V14.65 C16.6 13.45 16.15 12.75 15.15 12.75 C14.25 12.75 13.75 13.35 13.45 13.95 C13.35 14.2 13.3 14.5 13.3 14.85 V18.6 H10.6 V12.85 C10.6 11.8 10.55 10.9 10.35 10.15 Z" fill="currentColor" stroke="none" />
        </svg>
      )}
      <span class="sr-only">{link.label}</span>
    </a>
  ))}
</div>
