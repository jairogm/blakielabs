---
import Layout from "../Layout.astro";
import ProductModal from "../ProductModal.astro";
import { getLang, useTranslations } from "../../i18n/ui.js";

const lang = getLang(Astro);
const t = useTranslations(lang);
const work = t.work;
const products = t.products;
---

<Layout active="work" title={t.meta.work.title} description={t.meta.work.description}>
  <section class="section work page-section" aria-labelledby="work-title">
    <p class="section-kicker">{work.kicker}</p>
    <h1 class="page-heading" id="work-title">{work.title}</h1>

    <div class="tabs" role="tablist" aria-label={work.tablistAria}>
      <button class="tabs__button is-active" type="button" role="tab" aria-selected="true" aria-controls="clients-panel" id="clients-tab" data-tab-target="clients">{work.tabClients}</button>
      <button class="tabs__button" type="button" role="tab" aria-selected="false" aria-controls="products-panel" id="products-tab" data-tab-target="products">{work.tabProducts}</button>
    </div>

    <div class="work__panel is-active" id="clients-panel" role="tabpanel" aria-labelledby="clients-tab" data-tab-panel="clients">
      <div class="case-grid">
        {work.clients.map((client) => (
          <article class="case-card">
            <div class="case-card__top">
              <span>{client.sector}</span>
              <strong>{client.tag}</strong>
            </div>
            <h2>{client.name}</h2>
            <p>{client.desc}</p>
            {client.points ? (
              <ul class="case-card__list">
                {client.points.map((point) => <li>{point}</li>)}
              </ul>
            ) : (
              <div class="case-card__metrics">
                <span><strong>{client.metric}</strong>{client.metricLabel}</span>
                <span><strong>{client.metric2}</strong>{client.metric2Label}</span>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>

    <div class="work__panel" id="products-panel" role="tabpanel" aria-labelledby="products-tab" data-tab-panel="products" hidden>
      <div class="product-grid" id="products">
        {products.map((product) => (
          <article class="product-card">
            <div class="product-card__top">
              <span class={`app-icon app-icon--${product.iconClass}`}>
                <svg class="app-glyph" aria-hidden="true"><use href={`#pg-${product.slug}`} /></svg>
              </span>
              <small class={`status status--${product.statusClass}`}>{product.status}</small>
            </div>
            <h2>{product.name}</h2>
            <p>{product.desc}</p>
            <button class="text-link product-card__button" type="button" data-product-open={product.slug}>{work.viewCaseStudy}</button>
          </article>
        ))}
      </div>
    </div>
  </section>
  <ProductModal products={products} slot="overlays" />
</Layout>
