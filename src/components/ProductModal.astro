---
import { getLang, useTranslations } from "../i18n/ui.js";

const { products = [] } = Astro.props;
const lang = getLang(Astro);
const t = useTranslations(lang);
const m = t.modal;
---

<div class="modal" hidden data-product-modal>
  <div class="modal__backdrop" data-modal-close></div>
  <section class="modal__dialog" role="dialog" aria-modal="true" aria-labelledby="modal-title" aria-describedby="modal-desc" tabindex="-1">
    <button class="modal__close" type="button" aria-label={m.closeAria} data-modal-close>&times;</button>
    <div class="modal__header">
      <span class="app-icon app-icon--accent" data-modal-icon>
        <svg class="app-glyph" aria-hidden="true"><use href="#pg-shipbite" /></svg>
      </span>
      <div>
        <h2 id="modal-title" data-modal-title>Shipbite</h2>
        <small class="status status--incubator" data-modal-status>In Development</small>
      </div>
    </div>
    <p class="modal__tagline" id="modal-desc" data-modal-tagline></p>
    <div class="modal__section">
      <h3>{m.problem}</h3>
      <p data-modal-problem></p>
    </div>
    <div class="modal__section">
      <h3>{m.built}</h3>
      <ul data-modal-build></ul>
    </div>
    <div class="modal__section">
      <h3>{m.stack}</h3>
      <div class="modal__stack" data-modal-stack></div>
    </div>
    <button class="button button--primary modal__cta" type="button" data-modal-close data-modal-cta>{m.ctaDefault}</button>
  </section>
</div>

<script type="application/json" id="product-data" set:html={JSON.stringify(products)}></script>
