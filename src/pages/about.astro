---
import Layout from "../components/Layout.astro";
import { ethos, team } from "../data/site";
---

<Layout
  active="about"
  title="About | Blakie Labs"
  description="Meet Blakie Labs: a small senior engineering team focused on extreme quality, fast execution, and software built to last."
  canonicalPath="/about/"
>
  <section class="section about page-section" aria-labelledby="about-title">
    <p class="section-kicker">// THE MANIFEST</p>
    <h1 class="page-heading page-heading--narrow" id="about-title">Legendary code, or nothing at all.</h1>
    <p class="about__lead">We are a small pack of senior engineers who refuse to ship mediocre work. Extreme quality, ruthless agility, and a standing habit of moving out of the comfort zone to build things that outlast their hype cycle.</p>
    <p class="about__lead">No bloated teams. No hand-offs to junior devs. The people you talk to are the people writing the code.</p>

    <div class="ethos-grid">
      {ethos.map((item) => (
        <article class="ethos-card">
          <span>{item.num}</span>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
        </article>
      ))}
    </div>

    <article class="origin">
      <div class="origin__mark">
        <img class="origin__image" src="/blakie-origin.png" alt="" width="322" height="294" loading="lazy" decoding="async" />
      </div>
      <div>
        <p>ORIGIN - WHY &quot;BLAKIE&quot;</p>
        <h2>Named after our favorite black dog, Blakie Labs embodies <span>loyalty, high speed, and protective execution</span> over the codebases we build.</h2>
        <div class="origin__actions">
          <a class="button button--ghost button--small" href="/why-blakie/">Learn more →</a>
        </div>
      </div>
    </article>

    <div class="section-heading section-heading--spaced">
      <h2>Meet the pack.</h2>
      <p>[ THE PEOPLE WRITING THE CODE ]</p>
    </div>
    <div class="team-grid">
      {team.map((member) => (
        <article class={`team-card ${member.accent ? "team-card--accent" : ""}`}>
          <span class="team-card__avatar">
            {member.image ? <img src={member.image} alt={member.imageAlt || ""} width="720" height="720" loading="lazy" decoding="async" /> : <span class="team-card__initial">{member.initial}</span>}
          </span>
          <h2>{member.name}</h2>
          <p>{member.role}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
