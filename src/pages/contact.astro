---
import Layout from "../components/Layout.astro";
---

<Layout
  active="contact"
  title="Contact | Blakie Labs"
  description="Send Blakie Labs your product brief, retainer request, or architecture challenge. The team replies within 24 hours."
  canonicalPath="/contact/"
  newsletter={false}
>
  <section class="section contact page-section" aria-labelledby="contact-title">
    <div class="contact__inner" data-contact-card>
      <p class="section-kicker">// RETAINER INTAKE</p>
      <h1 class="page-heading" id="contact-title">Let's build something worth biting into.</h1>
      <p class="contact__intro">Tell us what you are working on. We reply to every brief within 24 hours.</p>

      <form class="form" novalidate data-contact-form>
        <fieldset class="form__choice">
          <legend>WHAT BRINGS YOU HERE?</legend>
          <label class="choice-card">
            <input type="radio" name="type" value="retainer" checked />
            <span>[01]</span>
            <strong>Monthly Retainer Partnership</strong>
          </label>
          <label class="choice-card">
            <input type="radio" name="type" value="architecture" />
            <span>[02]</span>
            <strong>Custom Architecture</strong>
          </label>
          <label class="choice-card">
            <input type="radio" name="type" value="hi" />
            <span>[03]</span>
            <strong>Just Saying Hi</strong>
          </label>
        </fieldset>

        <div class="form__grid">
          <label class="field">
            <span>NAME</span>
            <input id="name" name="name" autocomplete="name" placeholder="Jane Doe" required aria-describedby="name-error" />
            <small class="field__error" id="name-error" data-error-for="name" aria-live="polite"></small>
          </label>
          <label class="field">
            <span>COMPANY</span>
            <input id="company" name="company" autocomplete="organization" placeholder="Acme Inc." required aria-describedby="company-error" />
            <small class="field__error" id="company-error" data-error-for="company" aria-live="polite"></small>
          </label>
        </div>
        <label class="field">
          <span>EMAIL</span>
          <input id="email" name="email" type="email" autocomplete="email" placeholder="jane@acme.com" required aria-describedby="email-error" />
          <small class="field__error" id="email-error" data-error-for="email" aria-live="polite"></small>
        </label>
        <label class="field">
          <span>THE BRIEF / IDEA</span>
          <textarea id="brief" name="brief" rows="4" placeholder="What are you building? What's the timeline?" required minlength="12" aria-describedby="brief-error"></textarea>
          <small class="field__error" id="brief-error" data-error-for="brief" aria-live="polite"></small>
        </label>
        <button class="button button--primary form__submit" type="submit" data-submit-button>Transmit Brief →</button>
      </form>
    </div>

    <div class="contact__success" hidden data-contact-success tabindex="-1">
      <img class="contact__success-mark" src="/blakie-origin.png" alt="" loading="lazy" decoding="async" />
      <h2>Brief received. Blakie's on it.</h2>
      <p>We will fetch you a reply within 24 hours.</p>
      <button class="button button--ghost" type="button" data-reset-contact>Send another →</button>
    </div>
  </section>
</Layout>
