---
import Layout from "../components/Layout.astro";
import { agencyPoints, clientLogos, labPreview, stats, testimonials } from "../data/site";
---

<Layout
  active="home"
  title="Blakie Labs | Senior Software Studio and Product Lab"
  description="Blakie Labs builds high-performance software for clients and incubates sharp digital products with a senior-only engineering team."
  canonicalPath="/"
>
  <section class="hero section" id="home" aria-labelledby="hero-title">
    <div class="hero__copy">
      <p class="eyebrow"><span></span>DUAL-ENGINE DIGITAL STUDIO</p>
      <h1 class="hero__title" id="hero-title">We build software that <span>bites.</span></h1>
      <p class="hero__intro">Blakie Labs is a dual-engine digital studio. We ship high-performance software for global clients and incubate our own suite of digital applications.</p>
      <div class="hero__actions">
        <a class="button button--primary" href="/plans/">Hire the Lab <span>[Retainer Plans]</span></a>
        <a class="button button--ghost" href="/work/#products">Explore Our Apps →</a>
      </div>
    </div>

    <div class="hero-card" aria-label="Blakie Labs mark">
      <div class="hero-card__grid" aria-hidden="true"></div>
      <div class="hero-card__halo" aria-hidden="true"></div>
      <div class="hero-stack" aria-hidden="true">
        <span class="hero-stack__item hero-stack__item--js">JS</span>
        <span class="hero-stack__item hero-stack__item--react">React</span>
        <span class="hero-stack__item hero-stack__item--java">Java</span>
        <span class="hero-stack__item hero-stack__item--html">HTML</span>
        <span class="hero-stack__item hero-stack__item--css">CSS</span>
        <span class="hero-stack__item hero-stack__item--node">Node</span>
      </div>
      <img class="hero-card__mark" src="/blakie-origin.png" alt="" width="322" height="294" decoding="async" fetchpriority="high" />
      <p class="hero-card__caption">// blakie.exe - loyal by design</p>
    </div>
  </section>

  <section class="section model" aria-labelledby="model-title">
    <div class="section-heading">
      <h2 id="model-title">Two engines. One pack.</h2>
      <p>[ THE AGENCY ] x [ THE LAB ]</p>
    </div>

    <div class="model__grid">
      <article class="panel panel--large">
        <p class="panel__kicker">01 - THE AGENCY</p>
        <h3>Dedicated velocity, on retainer.</h3>
        <p>High-end monthly engineering retainers. Full-stack architecture, rapid MVPs, and a senior pack shipping production code on your roadmap.</p>
        <ul class="check-list">
          {agencyPoints.map((point) => <li>{point}</li>)}
        </ul>
        <a class="text-link" href="/plans/">View retainer plans</a>
      </article>

      <article class="panel panel--large">
        <p class="panel__kicker">02 - THE LAB</p>
        <h3>Apps we ship for ourselves.</h3>
        <p>A growing suite of proprietary SaaS, built in the open. Some live, some incubating in the kennel.</p>
        <div class="app-preview">
          {labPreview.map((app) => (
            <div class="app-preview__item">
              <span class={`app-icon app-icon--${app.iconClass}`}>{app.initial}</span>
              <span>
                <strong>{app.name}</strong>
                <small class={`status status--${app.statusClass}`}>{app.status}</small>
              </span>
            </div>
          ))}
        </div>
        <a class="text-link" href="/work/#products">Browse all products</a>
      </article>
    </div>

    <div class="stats">
      {stats.map((stat) => (
        <div class="stats__item">
          <strong>{stat.num}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section proof" aria-labelledby="proof-title">
    <p class="proof__kicker" id="proof-title">TRUSTED BY TEAMS THAT SHIP</p>
    <div class="proof__logos" aria-label="Client logos">
      {clientLogos.map((logo) => <span>{logo}</span>)}
    </div>
    <div class="testimonial-grid">
      {testimonials.map((item) => (
        <figure class="testimonial">
          <blockquote>
            <span class="testimonial__quote-mark" aria-hidden="true">&ldquo;</span>{item.quote}<span class="testimonial__quote-mark" aria-hidden="true">&rdquo;</span>
          </blockquote>
          <figcaption>
            <span class="testimonial__avatar" aria-hidden="true">
              {item.image ? <img src={item.image} alt="" width="720" height="720" loading="lazy" decoding="async" /> : <span class="testimonial__mark">&quot;</span>}
            </span>
            <strong>{item.name}</strong>
            <small>{item.org}</small>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
</Layout>
